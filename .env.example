# BoardReadyOps Environment Configuration
# Copy this file to .env and fill in your values.

# Logging
BOARDREADY_LOG_LEVEL=info          # Log level: debug, info, warn, error
BOARDREADY_LOG_FILE=                # Path to log file (optional)
BOARDREADY_LOG_FORMAT=text          # Log format: text, json
BOARDREADY_LOG_FILE_MAX_BYTES=      # Max log file size before rotation
BOARDREADY_LOG_FILE_RETENTION=      # Number of rotated log files to keep

# Nexar API (optional, for component lifecycle lookups)
NEXAR_CLIENT_ID=                    # Nexar API client ID
NEXAR_CLIENT_SECRET=                # Nexar API client secret

# Release verification (CI only)
ALLOW_MAJOR_RELEASE=false           # Set to true to permit semver-major releases

# Docs
NO_MKDOCS_2_WARNING=                # Set to 1 to suppress MkDocs 2 deprecation warnings

# Binary builds (CI only)
BUN_BINARY=                         # Path to Bun binary for binary builds
PA11Y_CHROME_PATH=                  # Path to Chrome/Chromium for accessibility tests
