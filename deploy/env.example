APP_URL=https://boardreadyops.oaslananka.dev
NEXT_PUBLIC_APP_URL=https://boardreadyops.oaslananka.dev
NODE_ENV=production

POSTGRES_USER=boardreadyops
POSTGRES_PASSWORD=change-this-before-deploy
POSTGRES_DB=boardreadyops
DATABASE_URL=postgresql://boardreadyops:change-this-before-deploy@postgres:5432/boardreadyops
REDIS_URL=redis://redis:6379

ARTIFACT_STORAGE_DRIVER=local
ARTIFACT_STORAGE_ROOT=/data/artifacts
ARTIFACT_DOWNLOAD_SIGNING_KEY=replace-with-at-least-32-random-characters

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

RUNNER_CALLBACK_SECRET=
SESSION_SECRET=
BOARDREADYOPS_RUNNER_RESULT_KEY=

# Default execution runs in each target repository's GitHub Actions environment.
BOARDREADYOPS_RUNNER_MODE=github-actions
BOARDREADYOPS_DISPATCH_WORKFLOW=readiness-runner.yml
BOARDREADYOPS_PUBLIC_URL=https://boardreadyops.oaslananka.dev
BOARDREADYOPS_RELEASE_REPOSITORIES=owner/repository
# BOARDREADYOPS_RELEASE_REPOSITORIES_FILE=/run/policies/repositories

# Optional enterprise/customer self-hosted mode only.
BOARDREADYOPS_SELF_HOSTED_RUNNER_LABEL=default
BOARDREADYOPS_SELF_HOSTED_RUNNER_REQUIRE_SAFE_MODE=1
