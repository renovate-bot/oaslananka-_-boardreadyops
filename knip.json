{
  "$schema": "https://unpkg.com/knip/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "src/cli/index.ts",
        "src/cli/binary.ts",
        "src/action/index.ts",
        "src/core/errors.ts",
        "scripts/*.mjs",
        "tests/**/*.test.ts",
        "tests/benchmark/**/*.ts"
      ],
      "project": ["src/**/*.ts", "tests/**/*.ts", "scripts/**/*.mjs"]
    }
  },
  "ignoreBinaries": ["mkdocs", "psql"]
}
