{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oaslananka/boardreadyops/schemas/agent-plan-v1.json",
  "title": "BoardReadyOps agent remediation plan",
  "description": "Machine-readable remediation plan emitted by `boardreadyops plan` for coding agents, EDA agents, review bots, and release automation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "tool",
    "generatedAt",
    "status",
    "exitCode",
    "summary",
    "projectRoot",
    "nextActions",
    "releaseActions"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "const": "boardreadyops"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "generatedAt": {
      "type": "string"
    },
    "status": {
      "enum": ["passed", "failed"]
    },
    "exitCode": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "nextActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "releaseActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "critical", "high", "medium", "low", "info", "maxSeverity", "failed"],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "info": {
          "type": "integer",
          "minimum": 0
        },
        "maxSeverity": {
          "enum": ["critical", "high", "medium", "low", "info", "none"]
        },
        "failed": {
          "type": "boolean"
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ruleId",
        "severity",
        "title",
        "resource",
        "evidence",
        "whyItMatters",
        "fixStrategy",
        "safeAutoFixPossible",
        "commandsToVerify"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "ruleId": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "resource": {
          "$ref": "#/$defs/resource"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "whyItMatters": {
          "type": "string",
          "minLength": 1
        },
        "fixStrategy": {
          "$ref": "#/$defs/fixStrategy"
        },
        "safeAutoFixPossible": {
          "type": "boolean"
        },
        "commandsToVerify": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": ["project", "schematic", "pcb", "bom", "pinmap", "firmware", "manifest"]
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "region": {
          "$ref": "#/$defs/region"
        },
        "boardCoordinates": {
          "$ref": "#/$defs/boardCoordinates"
        }
      }
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startLine", "endLine"],
      "properties": {
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "startColumn": {
          "type": "integer",
          "minimum": 1
        },
        "endColumn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "boardCoordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "units"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "layer": {
          "type": "string"
        },
        "units": {
          "enum": ["mm", "in"]
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "enum": ["definite", "high", "medium", "low"]
        }
      }
    },
    "fixStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "steps"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
