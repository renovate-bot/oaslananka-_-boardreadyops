{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oaslananka/boardreadyops/schemas/doctor-v1.json",
  "title": "BoardReadyOps doctor report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "tool", "checks", "recommendations"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "const": "boardreadyops"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "title", "items"],
        "properties": {
          "name": {
            "enum": ["runtime", "kicad", "adapters", "repository", "suppressions", "action"]
          },
          "title": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["severity", "message"],
              "properties": {
                "severity": {
                  "enum": ["pass", "warn", "fail", "info"]
                },
                "message": {
                  "type": "string"
                },
                "recommendation": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
