{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oaslananka/boardreadyops/schemas/findings-v1.json",
  "title": "BoardReadyOps findings report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "tool", "summary", "findings"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "const": "boardreadyops"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object"
    },
    "readiness": {
      "$ref": "#/$defs/readiness"
    },
    "policy": {
      "$ref": "#/$defs/policy"
    },
    "waivers": {
      "$ref": "#/$defs/waivers"
    },
    "status": {
      "enum": ["passed", "failed"]
    },
    "exitCode": {
      "type": "integer",
      "minimum": 0
    },
    "releaseMode": {
      "enum": ["prototype", "pilot", "production"],
      "description": "Manufacturing release context used for this run."
    },
    "projects": {
      "type": "array"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "fabrication": {
      "$ref": "#/$defs/fabrication"
    },
    "generatedAt": {
      "type": "string"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin"
      }
    },
    "bomRisk": {
      "type": "object",
      "description": "Aggregate BOM supply-chain risk summary from the bom.risk-score rule.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "waivers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active", "expired"],
      "properties": {
        "active": {
          "$ref": "#/$defs/waiverList"
        },
        "expired": {
          "$ref": "#/$defs/waiverList"
        }
      }
    },
    "waiverList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule", "owner", "reason", "expired", "matched"],
        "properties": {
          "rule": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "expires": {
            "type": "string"
          },
          "expired": {
            "type": "boolean"
          },
          "matched": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "enforced", "rules"],
      "properties": {
        "status": {
          "enum": ["pass", "fail"]
        },
        "enforced": {
          "type": "boolean"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "status", "message"],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "enum": [
                  "max-severity",
                  "max-findings",
                  "min-readiness-score",
                  "require-readiness-status",
                  "require-required-outputs",
                  "forbid-rules",
                  "forbid-expired-waivers"
                ]
              },
              "status": {
                "enum": ["pass", "fail"]
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "status",
        "blocking",
        "nonBlocking",
        "evidence",
        "missingRequired",
        "missingRecommended",
        "warnings"
      ],
      "properties": {
        "profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "service"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "service": {
              "type": "string"
            }
          }
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "enum": ["ready", "at-risk", "blocked"]
        },
        "blocking": {
          "type": "integer",
          "minimum": 0
        },
        "nonBlocking": {
          "type": "integer",
          "minimum": 0
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["output", "importance", "present"],
            "properties": {
              "output": {
                "type": "string"
              },
              "importance": {
                "enum": ["required", "recommended"]
              },
              "present": {
                "type": "boolean"
              }
            }
          }
        },
        "missingRequired": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingRecommended": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "fabrication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bom", "outputs"],
      "properties": {
        "bom": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["reference"],
            "properties": {
              "reference": {
                "type": "string"
              },
              "sourcePath": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "footprint": {
                "type": "string"
              },
              "manufacturer": {
                "type": "string"
              },
              "mpn": {
                "type": "string"
              },
              "lifecycle": {
                "type": "string"
              },
              "dnp": {
                "type": "boolean"
              },
              "quantity": {
                "type": "number"
              },
              "suppliers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "files"],
            "properties": {
              "kind": {
                "type": "string"
              },
              "files": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path", "digest"],
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "digest": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleId", "severity", "message", "resource", "fingerprint"],
      "properties": {
        "ruleId": {
          "$ref": "#/$defs/ruleId"
        },
        "severity": {
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "message": {
          "type": "string"
        },
        "project": {
          "type": "string"
        },
        "resource": {
          "type": "object",
          "required": ["path", "kind"],
          "properties": {
            "path": {
              "type": "string"
            },
            "kind": {
              "enum": ["project", "schematic", "pcb", "bom", "pinmap", "firmware", "manifest"]
            }
          }
        },
        "location": {
          "type": "object"
        },
        "details": {
          "type": "object"
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fix": {
          "$ref": "#/$defs/fixSuggestion"
        },
        "confidence": {
          "$ref": "#/$defs/confidenceLevel"
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "suppressed": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "ruleId": {
                "const": "bom.missing-mpn"
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/bomMissingMpnDetails"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ruleId": {
                "const": "bom.single-source"
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/bomSingleSourceDetails"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ruleId": {
                "const": "bom.eol-detection"
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/bomEolDetails"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ruleId": {
                "const": "bom.footprint-mismatch"
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/bomFootprintMismatchDetails"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ruleId": {
                "const": "bom.dnp-consistency"
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/bomDnpConsistencyDetails"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ruleId": {
                "type": "string",
                "pattern": "^pinmap\\."
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/pinmapDetails"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ruleId": {
                "const": "manufacturing.outputs-present"
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/manufacturingOutputDetails"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ruleId": {
                "const": "manufacturing.drill-coverage"
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/drillCoverageDetails"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "ruleId": {
                "type": "string",
                "pattern": "^release\\."
              }
            }
          },
          "then": {
            "properties": {
              "details": {
                "$ref": "#/$defs/releaseDetails"
              }
            }
          }
        }
      ]
    },
    "fixSuggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "automated": {
          "type": "boolean"
        }
      }
    },
    "confidenceLevel": {
      "enum": ["definite", "high", "medium", "low"]
    },
    "ruleId": {
      "oneOf": [
        {
          "enum": [
            "config.invalid",
            "environment.kicad-missing",
            "manifest.project-discovery",
            "gate.requirement",
            "bom.missing-mpn",
            "bom.single-source",
            "bom.eol-detection",
            "bom.lifecycle",
            "bom.footprint-mismatch",
            "bom.dnp-consistency",
            "bom.variant-consistency",
            "design.copper-balance",
            "design.board-outline",
            "pinmap.verify",
            "pinmap.unmapped-pin",
            "pinmap.collision",
            "pinmap.net-label",
            "manufacturing.outputs-present",
            "manufacturing.jobset-outputs",
            "manufacturing.panel-sanity",
            "manufacturing.fab-notes",
            "manufacturing.drill-coverage",
            "manufacturing.layer-stackup",
            "release.revision-set",
            "release.changelog-present",
            "release.tag-matches-revision",
            "release.version-format",
            "firmware.platformio-pin-contract",
            "manufacturing.fiducials",
            "manufacturing.tooling-holes",
            "manufacturing.position-coverage",
            "bom.risk-score",
            "firmware.esp-idf-pin-contract",
            "firmware.zephyr-pin-contract",
            "firmware.arduino-pin-contract",
            "firmware.stm32cubemx-pin-contract"
          ]
        },
        {
          "type": "string",
          "pattern": "^(drc|erc)\\.[A-Za-z0-9_.-]+$"
        }
      ]
    },
    "bomMissingMpnDetails": {
      "type": "object",
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "bomSingleSourceDetails": {
      "type": "object",
      "required": ["mpn", "supplier"],
      "properties": {
        "mpn": {
          "type": "string"
        },
        "supplier": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "bomEolDetails": {
      "type": "object",
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string"
        },
        "lifecycle": {
          "type": "string"
        },
        "mpn": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "bomFootprintMismatchDetails": {
      "type": "object",
      "required": ["bom", "pcb"],
      "properties": {
        "bom": {
          "type": "string"
        },
        "pcb": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "bomDnpConsistencyDetails": {
      "type": "object",
      "required": ["bomDnp", "pcbDnp"],
      "properties": {
        "bomDnp": {
          "type": "boolean"
        },
        "pcbDnp": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "pinmapDetails": {
      "type": "object",
      "properties": {
        "entry": {
          "type": "object"
        },
        "designator": {
          "type": "string"
        },
        "pin": {
          "type": "string"
        },
        "net": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "manufacturingOutputDetails": {
      "type": "object",
      "properties": {
        "required": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "drillCoverageDetails": {
      "type": "object",
      "properties": {
        "drillSize": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "releaseDetails": {
      "type": "object",
      "properties": {
        "revision": {
          "type": ["string", "null"]
        },
        "tag": {
          "type": "string"
        },
        "tagPattern": {
          "type": "string"
        },
        "missingRevisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "pluginPermission": {
      "enum": ["fs:read", "fs:write", "network", "process", "kicad-cli"]
    },
    "pluginPermissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "allowed", "denied", "approvedBy"],
      "properties": {
        "requested": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pluginPermission"
          }
        },
        "allowed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pluginPermission"
          }
        },
        "denied": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pluginPermission"
          }
        },
        "approvedBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specifier", "name", "version", "ruleIds", "permissions"],
      "properties": {
        "specifier": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "ruleIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permissions": {
          "$ref": "#/$defs/pluginPermissions"
        }
      }
    }
  }
}
