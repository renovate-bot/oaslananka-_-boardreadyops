{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oaslananka/boardreadyops/schemas/hbom-v1.json",
  "title": "BoardReadyOps CycloneDX hardware SBOM",
  "type": "object",
  "additionalProperties": false,
  "required": ["bomFormat", "specVersion", "version", "metadata", "components", "dependencies"],
  "properties": {
    "$schema": {
      "const": "https://cyclonedx.org/schema/bom-1.7.schema.json"
    },
    "bomFormat": {
      "const": "CycloneDX"
    },
    "specVersion": {
      "const": "1.7"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timestamp", "tools", "component"],
      "properties": {
        "timestamp": {
          "type": "string"
        },
        "tools": {
          "type": "object",
          "additionalProperties": false,
          "required": ["components"],
          "properties": {
            "components": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "name", "version"],
                "properties": {
                  "type": {
                    "const": "application"
                  },
                  "name": {
                    "const": "boardreadyops"
                  },
                  "version": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "component": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "name", "bom-ref"],
          "properties": {
            "type": {
              "const": "device"
            },
            "name": {
              "type": "string"
            },
            "bom-ref": {
              "type": "string"
            }
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "dependsOn"],
        "properties": {
          "ref": {
            "type": "string"
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "property": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "externalReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "url"],
      "properties": {
        "type": {
          "enum": ["distribution", "documentation", "website"]
        },
        "url": {
          "type": "string"
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "name", "bom-ref", "properties"],
      "properties": {
        "type": {
          "const": "device"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "bom-ref": {
          "type": "string"
        },
        "manufacturer": {
          "$ref": "#/$defs/entity"
        },
        "supplier": {
          "$ref": "#/$defs/entity"
        },
        "purl": {
          "type": "string"
        },
        "externalReferences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/externalReference"
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        }
      }
    }
  }
}
