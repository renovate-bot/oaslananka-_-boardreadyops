{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oaslananka/boardreadyops/schemas/release-manifest.schema.json",
  "title": "BoardReadyOps Release Manifest",
  "description": "Vendor handoff package manifest produced by boardreadyops. schemaVersion 1.",
  "type": "object",
  "required": [
    "schemaVersion",
    "tool",
    "generatedAt",
    "vendor",
    "decision",
    "requiredOutputs",
    "includedOutputs",
    "assumptions",
    "files"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Always 1 for this format."
    },
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "const": "boardreadyops" },
        "version": { "type": "string" }
      }
    },
    "generatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of manifest generation."
    },
    "vendor": {
      "type": "object",
      "required": ["id", "name", "service"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Vendor profile identifier (e.g. jlcpcb)." },
        "name": { "type": "string", "description": "Human-readable vendor name." },
        "service": { "type": "string", "description": "Service description (e.g. fabrication+assembly)." }
      }
    },
    "decision": {
      "type": "object",
      "required": ["status", "missingOutputs"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready", "incomplete"],
          "description": "ready when all required outputs are present; incomplete when one or more are missing."
        },
        "missingOutputs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Output kinds required by the vendor profile that were not found."
        }
      }
    },
    "requiredOutputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Output kinds required by the vendor profile."
    },
    "includedOutputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Output kinds that were discovered and included in this package."
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Assumptions from the vendor profile (e.g. service=fabrication+assembly)."
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["output", "source", "target", "sha256", "bytes"],
        "additionalProperties": false,
        "properties": {
          "output": { "type": "string", "description": "Output kind (e.g. gerber, drill, bom)." },
          "source": { "type": "string", "description": "Source file path relative to the project root." },
          "target": { "type": "string", "description": "Target file path relative to the package root." },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "SHA-256 hex digest of the file contents."
          },
          "bytes": {
            "type": "integer",
            "minimum": 0,
            "description": "File size in bytes."
          }
        }
      },
      "description": "Files included in the package with checksums and layout metadata."
    }
  }
}
